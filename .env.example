# ============================================
# ValMentor AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (PostgreSQL)
POSTGRES_DB=valmentor
POSTGRES_USER=valmentor_user
POSTGRES_PASSWORD=valmentor_secret_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://valmentor_user:valmentor_secret_password@postgres:5432/valmentor

# Valkey (Redis-compatible)
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_DB=0
VALKEY_URL=redis://valkey:6379/0

# Celery
CELERY_BROKER_URL=redis://valkey:6379/1
CELERY_RESULT_BACKEND=redis://valkey:6379/2

# AI Providers
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
BREETH_API_KEY=your-breeth-api-key
AI_PROVIDER=anthropic
AI_MODEL_ID=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3


# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (Console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Media / File Storage
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# Security
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
